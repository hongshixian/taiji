# 太极环境变量模板 — 复制为 .env 后修改

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string

# 数据库 (开发默认用 SQLite, 生产设置 PostgreSQL URL)
DATABASE_URL=sqlite:///../data/taiji.db

# Redis (Celery 后端)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES=1800
JWT_REFRESH_TOKEN_EXPIRES=604800

# 初始管理员账号
# 仅在首次部署（数据库无 admin 时）生效
# 留空则启动时随机生成密码并打印到日志（推荐至少设置 ADMIN_PASSWORD）
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@taiji.local
# ADMIN_PASSWORD=  # ← 取消注释并设置强密码（≥12 字符）